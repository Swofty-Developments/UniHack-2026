# Physical iPhone on the same Wi-Fi as your dev machine
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3001/api

# Android Studio emulator
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/api

# Expo web in a local browser
# EXPO_PUBLIC_API_URL=http://localhost:3001/api

# Mapbox
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token_here
