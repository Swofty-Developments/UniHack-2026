{
  "expo": {
    "name": "AccessAtlas",
    "slug": "accessatlas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AccessAtlas needs your location to show nearby accessible spaces on the map.",
        "NSCameraUsageDescription": "AccessAtlas uses the camera to scan indoor spaces for accessibility mapping."
      }
    },
    "android": {
      "package": "com.accessatlas.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@rnmapbox/maps"
    ],
    "extra": {
      "apiUrl": "http://localhost:3001/api"
    }
  }
}
