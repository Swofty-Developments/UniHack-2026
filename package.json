    "@react-three/fiber": "^9.5.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.577.0",
    "next": "^15.2.3",
    "next-auth": "5.0.0-beta.30",
    "prisma": "^6.19.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.2",
    "three-pathfinding": "^1.3.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.15",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.1",
    "@types/uuid": "^11.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2"
  },
  "ct3aMetadata": {
